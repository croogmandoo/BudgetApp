# BudgetApp environment template.
#
# Copy this file to `.env` and fill in real values before running `make up`.
# `.env` is gitignored; `.env.example` is tracked and should never contain
# real secrets.
#
# Every value marked REPLACE_ME must be changed before first run.

# -----------------------------------------------------------------------------
# Encryption (SPEC.md §7.2)
# -----------------------------------------------------------------------------
# Master key that wraps every per-row / per-file data encryption key.
#
#   !!! LOSING THIS KEY DESTROYS ALL ENCRYPTED DATA. !!!
#   Encrypted columns (TOTP secrets, webhook secrets, future aggregator
#   tokens) and every attachment at rest become permanently unreadable
#   if APP_MASTER_KEY is lost. Back it up out-of-band (password manager,
#   offline copy) BEFORE putting real data into the system.
#
# Generate a fresh 32-byte base64 value with:
#   openssl rand -base64 32
APP_MASTER_KEY=REPLACE_ME_WITH_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
# Credentials for the `db` service. DATABASE_URL below composes them for the
# app — keep the three values in sync with the URL.
POSTGRES_USER=budgetapp
POSTGRES_PASSWORD=REPLACE_ME_WITH_A_STRONG_DB_PASSWORD
POSTGRES_DB=budgetapp

# Connection string the app uses. Hostname `db` is the compose service name.
DATABASE_URL=postgres://budgetapp:REPLACE_ME_WITH_A_STRONG_DB_PASSWORD@db:5432/budgetapp

# -----------------------------------------------------------------------------
# Redis (Celery broker + result backend)
# -----------------------------------------------------------------------------
# Hostname `redis` is the compose service name. Database 0 is fine for a
# single-tenant household deployment.
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Random 50-character secret used for signing sessions, CSRF tokens, etc.
# Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(50))'
DJANGO_SECRET_KEY=REPLACE_ME_WITH_python_secrets_token_urlsafe_50

# 0 = production-safe (no debug pages, no verbose errors). Flip to 1 only in
# local development.
DJANGO_DEBUG=0

# Comma-separated hostnames Django will answer to. Include the public hostname
# you deploy under plus `localhost` for local development.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated ORIGINS (scheme + host + port) that may submit state-changing
# requests. These must be full URLs, not bare hostnames.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Public URL where the SPA is served from. Used by the backend for building
# email links, webhook callbacks pointing back to the UI, etc.
FRONTEND_URL=http://localhost:3000

# Public URL the browser uses to reach the REST API. Baked into the SvelteKit
# bundle at build time — changing this requires `make up` (which rebuilds),
# not just a container restart.
VITE_API_URL=http://localhost:8000/api/v1

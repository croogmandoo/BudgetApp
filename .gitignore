# --- Node / SvelteKit --------------------------------------------------------
node_modules/
.svelte-kit/
.vite/
coverage/

# --- Environment / secrets ---------------------------------------------------
# Ignore every .env* file by default...
.env
.env.*
# ...but keep the tracked template that ships with the repo.
!.env.example

# --- Django runtime artifacts ------------------------------------------------
backend/staticfiles/
*.sqlite3
celerybeat-schedule
celerybeat.pid

# --- Logs --------------------------------------------------------------------
*.log
logs/

# --- OS / IDE ----------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Claude Code -------------------------------------------------------------
# Local AI assistant memory — personal to each developer's session.
.claude/

# --- Git worktrees -----------------------------------------------------------
.worktrees/

# --- Docker ------------------------------------------------------------------
# Operator-specific overrides shouldn't be committed. The base compose file is.
docker-compose.override.yml

# Lockfiles (poetry.lock, uv.lock, pnpm-lock.yaml) are intentionally NOT
# ignored — they must be committed to make builds reproducible.
